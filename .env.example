# MediGuard Production Environment Variables
# Copy this file to .env and fill in the values

# The base URL for the AI API (e.g., your LocalTunnel URL or a Cloud API URL)
VITE_AI_API_URL=

# The specific model ID to use
VITE_MODEL_ID=qwen2.5-0.5b-instruct-generic-gpu:4

# Optional: API Key if using a cloud provider (like Groq/OpenAI)
VITE_API_KEY=not-needed
