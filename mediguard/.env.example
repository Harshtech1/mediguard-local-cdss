# ─── Clerk Auth ───────────────────────────────────────────────────────────────
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_key_here
CLERK_SECRET_KEY=sk_test_your_clerk_secret_here

# ─── Supabase ──────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ─── Groq AI (Chat + Vision) ───────────────────────────────────────────────────
# Get key from: https://console.groq.com/keys
VITE_GROQ_API_KEY=gsk_your_groq_api_key_here

# ─── ElevenLabs TTS (Voice Assistant) ─────────────────────────────────────────
# Get key from: https://elevenlabs.io/app/speech-synthesis
# VITE_ prefix is REQUIRED so Vite exposes it to the browser
VITE_ELEVENLABS_API_KEY=sk_your_elevenlabs_key_here
# Voice ID — default "Sarah" (calm, medical). Find more at https://elevenlabs.io/voice-library
VITE_ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL

# ─── Stripe (Payments) ────────────────────────────────────────────────────────
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_key_here
